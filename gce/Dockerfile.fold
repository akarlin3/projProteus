# Proteus — GCE BURST fold image (S3). ESMFold batch fold, CPU build. Build/push ONLY
# when bursting; this is NOT part of the local M4 env and must NOT be built on the Mac.
# The local pipeline narrows S0–S2 and ships only the S2 shortlist up here (see gce/sync.md).
#
# CPU fold: this project has no GPU quota, so we fold ESMFold on CPU on a C4 VM. ESMFold
# on CPU runs fp32 and is RAM-heavy + slow, but the narrowed shortlist is small. (To move
# to GPU later: switch the base to nvidia/cuda:12.4.1-cudnn-runtime-ubuntu22.04, install the
# +cu124 torch wheel, set compute.gce_burst.accelerator, and proteus.launch builds the GPU plan.)
#
# Pin the toolchain on the FIRST real build and record the resolved versions next to the
# local lockfiles in envlog/. Packages carry __PIN_ON_FIRST_BUILD__ markers, not guesses.

# CPU base — no CUDA. Slim Debian + Python 3.11.
FROM python:3.11-slim-bookworm

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_NO_CACHE_DIR=1 \
    PYTHONUNBUFFERED=1 \
    OMP_NUM_THREADS=8 \
    HF_HOME=/data/hf-cache

RUN apt-get update && apt-get install -y --no-install-recommends \
        git wget ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /opt/proteus

RUN python3 -m pip install --upgrade pip

# --- ESMFold (S3 — the reason this box exists), CPU build ----------------------
# fair-esm provides ESMFold (esmfold_v1). Install the CPU torch wheel (no CUDA) plus
# the OpenFold deps ESMFold needs (dllogger, openfold). Pin all on the first build
# and capture the exact versions into envlog/.
# RUN pip3 install "torch==__PIN_ON_FIRST_BUILD__" --index-url https://download.pytorch.org/whl/cpu
# RUN pip3 install "fair-esm[esmfold]==__PIN_ON_FIRST_BUILD__"
# RUN pip3 install 'dllogger @ git+https://github.com/NVIDIA/dllogger.git' \
#                  'openfold @ git+https://github.com/aqlaboratory/openfold.git@__PIN__'

# --- GPU docking (GNINA / DiffDock) lives in the P4 burst, kept out of this image.

# The burst runner: read the S3 job manifest, fold the shortlist (CPU), write PDBs +
# per-model pLDDT to /data/proteus/out — checkpointed per sequence (a preempted SPOT VM
# resumes from the bucket, not refolds). Invoked with --device cpu. See gce/sync.md.
COPY gce/run_fold.py /opt/proteus/run_fold.py
ENTRYPOINT ["python3", "/opt/proteus/run_fold.py"]
# Default args (override at `docker run` / `gcloud` time):
CMD ["--help"]
